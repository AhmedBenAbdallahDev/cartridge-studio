# ── CARTRIDGE STUDIO ENVIRONMENT CONFIGURATION ────────────────────────────────

# Gemini API Key (Required for AI generation features)
# Get your key from: https://aistudio.google.com/
VITE_GEMINI_API_KEY=your_gemini_api_key_here

# ScreenScraper API Developer Credentials (Optional but recommended)
# Register at: https://www.screenscraper.fr/
# NOTE: Never commit actual keys. Copy this file to '.env.local' and edit it there.
VITE_SCREENSCRAPER_DEV_ID=your_developer_id_here
VITE_SCREENSCRAPER_DEV_PASSWORD=your_developer_password_here
VITE_SCREENSCRAPER_SOFT_NAME=CartridgeStudio

# ScreenScraper API User Credentials (Optional for high-quota registered users)
VITE_SCREENSCRAPER_USER_ID=
VITE_SCREENSCRAPER_USER_PASSWORD=
