# ── SYSTEM DUMPS & LOGS ────────────────────────────────────────────────────────
logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# ── DEPENDENCIES & BUILD OUTPUTS ──────────────────────────────────────────────
node_modules/
dist/
dist-ssr/
build/
.cache/

# ── ENVIRONMENT VARIABLES & API SECRETS ───────────────────────────────────────
# Block all environment files containing sensitive credentials (Gemini, ScreenScraper, etc.)
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
.env.*.local
*.env

# ── API SCRAPING & LOCAL JSON CACHES ──────────────────────────────────────────
# Exclude ScreenScraper raw responses and temporary data dumps containing API keys
response.json
out.json
raw.json
local_fetch_test.json
*.local.json
credentials.json

# ── EDITOR CONFIGURATIONS ──────────────────────────────────────────────────────
.vscode/*
!.vscode/extensions.json
.idea/
.DS_Store
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?
*.bak
Thumbs.db
temp_git/
.agent/


